PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
MONGODB_DB=excel-to-quiz

# Frontend origins allowed to call this API.
# Separate multiple origins by comma. Wildcard is supported for Vercel preview deployments.
CORS_ORIGIN=http://localhost:3000,https://your-frontend.vercel.app,https://*.vercel.app

# AI provider configuration
AI_PROVIDER=generic
AI_API_URL=http://your-provider-host/v1
AI_API_KEY=
AI_MODEL=your-primary-model
AI_MODEL_FALLBACKS=your-fallback-model-1,your-fallback-model-2

# Optional, currently not required by the quiz upload flow.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
